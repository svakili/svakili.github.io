---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../config/site";
---

<BaseLayout>
  <section class="container home-hero">
    <p class="eyebrow">Personal site</p>
    <h1>{siteConfig.name}</h1>
    <p class="lede">
      A personal site in progress, beginning with a living list of books that changed
      my life.
    </p>
    <div class="hero-actions">
      <a class="button-link" href="/books">Enter the Books section</a>
    </div>
  </section>

  <section class="container home-note surface-card">
    <div class="note-copy">
      <h2>Beginning with one real page</h2>
      <p class="lede">
        This first version is intentionally spare. The foundation is here for future
        essays, notes, and an About page, but Books is the only public section for
        now.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .home-hero {
    padding: clamp(5rem, 15vw, 9rem) 0 3rem;
  }

  .home-hero .lede {
    margin-top: 1rem;
    font-size: clamp(1.15rem, 2.3vw, 1.45rem);
  }

  .hero-actions {
    margin-top: 2rem;
  }

  .home-note {
    margin-top: 1rem;
    padding: clamp(1.4rem, 3vw, 2rem);
  }

  .note-copy {
    display: grid;
    gap: 0.8rem;
  }
</style>
