---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../config/site";
---

<BaseLayout>
  <section class="container home-hero">
    <h1>{siteConfig.name}</h1>
    <div class="hero-actions">
      <a class="button-link" href="/books">Enter the Books section</a>
    </div>
  </section>
</BaseLayout>

<style>
  .home-hero {
    padding: clamp(5rem, 15vw, 9rem) 0 3rem;
  }

  .hero-actions {
    margin-top: 1.75rem;
  }
</style>
