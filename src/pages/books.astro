---
import BookEntry from "../components/BookEntry.astro";
import PageIntro from "../components/PageIntro.astro";
import { books, booksMeta } from "../data/books";
import BaseLayout from "../layouts/BaseLayout.astro";

const updatedLabel = new Intl.DateTimeFormat("en-US", {
  month: "long",
  year: "numeric"
}).format(new Date(booksMeta.updatedAt));
---

<BaseLayout title="Books" description="Books that have had an impact on me.">
  <section class="container-wide books-page">
    <PageIntro
      title="Books"
      lead="The books that have had an impact on me."
      meta={[`${booksMeta.count} books`, `Updated ${updatedLabel}`]}
    />

    <div class="books-preface surface-card">
      <p>The list below is <strong>absolutely unranked</strong>.</p>
      <p>
        It changes over time. One book gets added each year, and the list can also
        shift as some books fall away and others earn their place.
      </p>
    </div>

    <section class="books-list" aria-label="Books that changed my life">
      {books.map((book, index) => <BookEntry book={book} number={index + 1} />)}
    </section>
  </section>
</BaseLayout>

<style>
  .books-page {
    padding-bottom: 1.5rem;
  }

  .books-preface {
    margin: 0 0 2rem;
    display: grid;
    gap: 0.45rem;
    padding: 1.1rem 1.25rem;
    color: var(--color-muted);
  }

  .books-preface strong {
    color: var(--color-ink);
  }

  .books-list {
    margin-top: 0.5rem;
  }
</style>
