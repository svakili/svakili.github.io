---
import type { BookRecord } from "../types/books";

type Props = {
  book: BookRecord;
};

const { book } = Astro.props;
const entryUrl = `/books#${book.slug}`;
const hasLinks = Boolean(book.goodreadsUrl || book.amazonUrl);
const hasCover = Boolean(book.coverImage);
---

<article class="book-entry" id={book.slug}>
  <div class:list={["entry-grid", !hasCover && "is-coverless"]}>
    {
      book.coverImage && (
        <div class="cover-shell">
          <img
            class="cover-image"
            src={book.coverImage}
            alt={`Cover of ${book.title}`}
            loading="lazy"
            decoding="async"
          />
        </div>
      )
    }

    <div class="entry-copy">
      <header class="entry-header">
        <h2 class="entry-title">
          <a href={entryUrl}>{book.title}</a>
        </h2>
        {book.author && <p class="entry-author">{book.author}</p>}
      </header>

      {book.quote && <blockquote>{book.quote}</blockquote>}
      {book.myTake && <div class="entry-take prose"><p>{book.myTake}</p></div>}

      {
        hasLinks && (
          <div class="entry-links" aria-label={`External links for ${book.title}`}>
            {book.goodreadsUrl && (
              <a
                class="link-inline"
                href={book.goodreadsUrl}
                target="_blank"
                rel="noreferrer"
              >
                Goodreads
              </a>
            )}
            {book.amazonUrl && (
              <a
                class="link-inline"
                href={book.amazonUrl}
                target="_blank"
                rel="noreferrer"
              >
                Amazon
              </a>
            )}
          </div>
        )
      }
    </div>
  </div>
</article>

<style>
  .book-entry {
    position: relative;
    padding: 1.75rem 0;
    border-top: 1px solid var(--color-rule);
    scroll-margin-top: 5rem;
  }

  .entry-grid {
    display: grid;
    grid-template-columns: minmax(0, 7.5rem) minmax(0, 1fr);
    gap: 1.5rem 1.75rem;
    align-items: start;
  }

  .cover-shell {
    max-width: 7.5rem;
  }

  .entry-grid.is-coverless {
    grid-template-columns: 1fr;
  }

  .cover-image {
    width: 100%;
    aspect-ratio: 2 / 3;
    object-fit: cover;
    border-radius: 1rem;
    border: 1px solid rgba(32, 29, 26, 0.12);
    background: rgba(255, 255, 255, 0.72);
    box-shadow: var(--shadow-soft);
  }

  .entry-copy {
    display: grid;
    gap: 1rem;
    min-width: 0;
  }

  .entry-header {
    display: grid;
    gap: 0.35rem;
  }

  .entry-title {
    font-size: clamp(1.5rem, 2vw, 2rem);
  }

  .entry-title a {
    color: inherit;
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .entry-title a:hover,
  .entry-title a:focus-visible {
    color: var(--color-accent);
  }

  .entry-author {
    color: var(--color-muted);
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.01em;
  }

  .entry-take {
    max-width: 44rem;
  }

  .entry-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem 1.1rem;
    font-size: 0.98rem;
  }

  @media (max-width: 760px) {
    .entry-grid {
      grid-template-columns: 1fr;
    }

    .cover-shell {
      max-width: 6.25rem;
    }
  }
</style>
